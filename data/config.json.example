{
  "backends": {
    "backends": []
  },
  "auto_deploy": {
    "accounts": {}
  },
  "panel_acl": {
    "allowed_ips": []
  },
  "ssh_targets": {
    "panel_key_path": "data/panel_tunnel_key",
    "default_target": "vps1",
    "targets": {
      "vps1": {
        "host": "1.2.3.4",
        "ssh_port": 22,
        "tunnel_user": "tunnel",
        "upstream_host": "127.0.0.1",
        "port_range": [19080, 19980]
      }
    },
    "assignments": {}
  },
  "pin": {
    "aistudio_pin_ip": ""
  },
  "mimo_control": {
    "ssh": {
      "enabled": false,
      "target": "root@1.2.3.4",
      "port": 22,
      "identity_file": "",
      "timeout": 45
    }
  }
}
