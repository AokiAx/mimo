# 主控面板地址(公网可达)。worker 只往这里出站。
PANEL_URL=https://panel.example.com

# 面板"Claw Workers"页给本 worker 签发的 token
WORKER_TOKEN=replace-me

# 面板上显示的名字(默认用容器 hostname)
WORKER_NAME=nas-mainland-01

# 空闲轮询间隔(秒)
POLL_INTERVAL=60

# 单次建 claw 的最长重试预算(秒)
CLAW_CREATE_BUDGET=600

# 可选:本机若不是大陆出口,但同局域网有个大陆出口代理,填它的 SOCKS。
# 本机自身就是大陆 IP 时留空。
# MIMO_PROXY=socks5://192.168.1.50:1080

# 面板用自签证书时设 0 关闭 TLS 校验(不建议公网这么干)
# VERIFY_TLS=1
